rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email.lower() == "joseralpharrojado789@gmail.com" || 
              request.auth.token.email.lower() == "joseralpharrojado909@gmail.com") && 
             request.auth.token.email_verified == true;
    }

    function isSystemAdmin() {
      return isAdmin();
    }

    function isMechanic() {
      return isAuthenticated() && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'mechanic' || isAdmin());
    }

    function isVerifiedMechanic() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isMechanic() && (userData.get('isVerified', false) == true || isAdmin());
    }

    function isValidRescue(data) {
      return data.customerId is string &&
             data.status in ['pending', 'accepted', 'in-progress', 'completed', 'cancelled'] &&
             data.location is map &&
             data.location.lat is number &&
             data.location.lng is number &&
             data.issue is string &&
             (!('issueCategory' in data) || data.issueCategory in ['Engine', 'Battery', 'Tire', 'Fuel', 'Lockout', 'Other']);
    }

    function isRecentRequest() {
      // Rate limit: 5 minutes between requests (Admins bypass)
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      let lastRequest = userData.get('lastRequestAt', null);
      return isAdmin() || lastRequest == null || request.time > lastRequest + duration.value(5, 'm');
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && 
                      request.resource.data.role in ['customer', 'mechanic'] &&
                      (isAdmin() || 
                       !('isVerified' in request.resource.data) || 
                       request.resource.data.isVerified == false);
      allow update: if isAdmin() || (
        isOwner(userId) && 
        request.resource.data.role == resource.data.role &&
        (request.resource.data.get('isVerified', false) == resource.data.get('isVerified', false)) &&
        (!('application' in request.resource.data) || (
          resource.data.role == 'mechanic' && 
          (!('status' in request.resource.data.application) || 
           !('application' in resource.data) || 
           request.resource.data.application.status == resource.data.application.status)
        ))
      );
    }

    match /settings/pricing {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /rescues/{rescueId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                      request.resource.data.customerId == request.auth.uid &&
                      request.resource.data.status == 'pending' &&
                      isValidRescue(request.resource.data) &&
                      isRecentRequest();

      allow update: if isAuthenticated() && (
        isAdmin() ||
        (request.auth.uid == resource.data.customerId && 
         (resource.data.status != 'completed' || 
          (!('rating' in resource.data) && 
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'review', 'ratedAt'])))) ||
        request.auth.uid == resource.data.mechanicId ||
        (isVerifiedMechanic() && resource.data.status == 'pending' && request.resource.data.status == 'accepted')
      ) && isValidRescue(request.resource.data);

      match /messages/{messageId} {
        allow read: if isAuthenticated() && (
          request.auth.uid == get(/databases/$(database)/documents/rescues/$(rescueId)).data.customerId ||
          request.auth.uid == get(/databases/$(database)/documents/rescues/$(rescueId)).data.mechanicId ||
          isAdmin()
        );
        allow create: if isAuthenticated() && (
          request.auth.uid == get(/databases/$(database)/documents/rescues/$(rescueId)).data.customerId ||
          request.auth.uid == get(/databases/$(database)/documents/rescues/$(rescueId)).data.mechanicId
        ) && request.resource.data.senderId == request.auth.uid;
      }
    }
  }
}
